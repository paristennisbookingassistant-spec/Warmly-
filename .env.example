# ============================================================
# AI Networking Coach — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase (required) ----
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose in browser
SUPABASE_SERVICE_KEY=your-service-role-key

# ---- Anthropic (required) ----
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ---- Company Intelligence Search (optional) ----
# Primary: Perplexity API — https://www.perplexity.ai/
PERPLEXITY_API_KEY=pplx-...
# Fallback: SerpAPI — https://serpapi.com/
SERPAPI_KEY=your-serpapi-key

# ---- App URL (required for OAuth callbacks) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
